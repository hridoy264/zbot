<?xml version="1.0" ?>
<robot name="zbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$package://urdf/materials.xacro" />
<xacro:include filename="$package://urdf/zbot.ros2control.xacro" />
<xacro:include filename="$package://urdf/zbot.gazebo.xacro" />

<link name="base_footprint"/>
<joint name = "base_footprint_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.02" rpy="0 0 0"/> 
</joint>
<link name="base_link">
  <inertial>
    <origin xyz="0.0 0.0 0.005" rpy="0 0 0"/>
    <mass value="0.9450826877913348"/>
    <inertia ixx="0.000801" iyy="0.001146" izz="0.001931" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="lb_wheel_1">
  <inertial>
    <origin xyz="-4.1874584825324357e-07 -0.0049999999999999975 7.806255641895632e-18" rpy="0 0 0"/>
    <mass value="0.1541343895667492"/>
    <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.049055 0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/lb_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.049055 0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/lb_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="lf_wheel_1">
  <inertial>
    <origin xyz="4.1874584825324357e-07 -0.0049999999999999975 7.806255641895632e-18" rpy="0 0 0"/>
    <mass value="0.1541343895667492"/>
    <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.049055 0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/lf_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.049055 0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/lf_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  <!-- Front left wheel friction -->
  <gazebo reference="lf_wheel_1">
    <mu1>0.8</mu1>
    <mu2>0.3</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>
</link>

<link name="rb_wheel_1">
  <inertial>
    <origin xyz="-4.1874584825324357e-07 0.0049999999999999975 -6.938893903907228e-18" rpy="0 0 0"/>
    <mass value="0.1541343895667492"/>
    <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="-0.0" iyz="0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.049055 -0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/rb_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.049055 -0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/rb_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="rf_wheel_1">
  <inertial>
    <origin xyz="4.1874584825324357e-07 0.0049999999999999975 -6.938893903907228e-18" rpy="0 0 0"/>
    <mass value="0.1541343895667492"/>
    <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="0.0" iyz="0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.049055 -0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/rf_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.049055 -0.055 -0.005" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://zbot_description/meshes/rf_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="lb_wheel_joint" type="continuous">
  <origin xyz="-0.049055 0.055 0.005" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lb_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="lf_wheel_joint" type="continuous">
  <origin xyz="0.049055 0.055 0.005" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lf_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="rb_wheel_joint" type="continuous">
  <origin xyz="-0.049055 -0.055 0.005" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="rb_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="rf_wheel_joint" type="continuous">
  <origin xyz="0.049055 -0.055 0.005" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="rf_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>




</robot>
